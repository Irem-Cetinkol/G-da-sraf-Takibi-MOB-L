<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center"
    android:background="@drawable/kutu_beyaz_oval">

    <ImageView
        android:id="@+id/imgBilgiIkon"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/txtBilgiBaslikUrunAdi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#3E2723"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/txtBilgiMiktar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#3E2723"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtBilgiAcilma"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#3E2723"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtBilgiTett"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#B71C1C"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnBilgiTuket"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tüket 🍽️"
            android:backgroundTint="#E0F2F1"
            android:textColor="#004D40"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnBilgiSil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Çöpe At 🗑️"
            android:backgroundTint="#FFEBEE"
            android:textColor="#B71C1C"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnBilgiKapat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#ECEFF1"
        android:textColor="#37474F"
        android:layout_marginTop="12dp"
        android:text="Kapat"/>

</LinearLayout>